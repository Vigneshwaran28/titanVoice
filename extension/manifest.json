{
  "manifest_version": 3,
  "name": "TitanVoice",
  "version": "0.1.0",
  "description": "Live transcription and AI sales suggestions during video calls (Google Meet, Zoom Web, etc.)",
  "permissions": ["tabCapture", "activeTab", "scripting", "storage", "offscreen"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "ws://localhost:8765/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TitanVoice"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*", "https://*.zoom.us/*"],
      "js": ["content.js"],
      "css": ["overlay.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
